# Wallet (NEVER commit real values)
WDK_SEED=           # 12-word mnemonic for WDK (primary)
ETH_PRIVATE_KEY=    # Hex private key (fallback if WDK_SEED not set)
ETH_RPC_URL=https://sepolia.base.org

# AI Reasoning (optional)
ANTHROPIC_API_KEY=  # Enables Claude-powered treasury analysis

# Server
PORT=3000
NODE_ENV=development

# Tokens — Aave V3 Base Sepolia testnet
USDT_CONTRACT=0x0a215D8ba66387DCA84B284D18c3B4ec3de6E54a
USDC_CONTRACT=0xba50Cd2A20f6DA35D788639E581bca8d0B5d4D5f
WETH_CONTRACT=0x4200000000000000000000000000000000000006

# Aave V3 Base Sepolia
AAVE_POOL=0x8bAB6d1b75f19e9eD9fCe8b9BD338844fF79aE27
AAVE_DATA_PROVIDER=0xBc9f5b7E248451CdD7cA54e717a2BFe1F32b566b
AAVE_FAUCET=0xD9145b5F45Ad4519c7ACcD6E0A4A82e83bB8A6Dc

# Aave V3 Base Sepolia aToken addresses
ATOKEN_USDT=0xcE3CAae5Ed17A7AafCEEbc897DE843fA6CC0c018
ATOKEN_USDC=0x10F1A9D11CDf50041f3f8cB7191CBE2f31750ACC
ATOKEN_WETH=0x73a5bB60b0B0fc35710DDc0ea9c407031E31Bdbb

# Uniswap V3 Base Sepolia (swap fallback when Velora unavailable)
UNISWAP_ROUTER=0x94cC0AaC535CCDB3C01d6787D6413C739ae12bc4
UNISWAP_QUOTER=0xC5290058841028F1614F3A6F0F5816cAd0df5E27
UNISWAP_FACTORY=0x4752ba5DBc23f44D87826276BF6Fd6b1C372aD24

# ERC-4337 Account Abstraction (optional — enables gasless tx)
# ERC4337_BUNDLER_URL=https://api.pimlico.io/v2/sepolia/rpc?apikey=YOUR_KEY
# ERC4337_PAYMASTER_URL=     # Paymaster service URL (for USDT gas payment)
# ERC4337_PAYMASTER_ADDRESS= # Paymaster contract address
# ERC4337_PAYMASTER_TOKEN=   # Token to pay gas (e.g. USDT address)

# x402 Agentic Payments (optional — enables machine-to-machine USDT0 payments)
# Uses @t402/* packages (Tether's implementation of x402 protocol)
# X402_NETWORK=eip155:42161          # Arbitrum mainnet (USDT0 is mainnet-only)
# X402_TOKEN=                        # Auto-detected from @t402/wdk USDT0_ADDRESSES
# X402_FACILITATOR=https://facilitator.t402.io

# ─── Multi-chain Presets ───
# Override defaults by setting CHAIN (uses pre-configured chain in src/evm/chains.js)
# CHAIN=baseSepolia                  # Default (testnet, Aave V3 on Base Sepolia)
# CHAIN=arbitrum                     # Arbitrum One mainnet (recommended for x402 + Velora demo)
# CHAIN=ethereum                     # Ethereum mainnet
# CHAIN=base                         # Base mainnet
