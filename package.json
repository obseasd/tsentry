{
  "name": "tsentry",
  "version": "0.1.0",
  "description": "Autonomous Multi-Chain Treasury Agent — WDK + OpenClaw",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node src/server.js",
    "mcp": "node src/mcp-server.js",
    "start": "NODE_ENV=production node src/server.js",
    "test": "node --test src/*.test.js src/**/*.test.js",
    "demo": "bash scripts/demo.sh",
    "demo:fast": "bash scripts/demo.sh --fast",
    "demo:a2a": "node scripts/demo-agent2agent.js --simulate"
  },
  "keywords": [
    "wdk",
    "tether",
    "openclaw",
    "mcp",
    "treasury",
    "agent"
  ],
  "license": "Apache-2.0",
  "dependencies": {
