    "@modelcontextprotocol/sdk": "^1.27.1",
    "@t402/core": "^2.7.1",
    "@t402/evm": "^2.7.1",
    "@t402/express": "^2.7.1",
    "@t402/fetch": "^2.7.1",
    "@t402/wdk": "^2.6.1",
    "@tetherto/wdk-mcp-toolkit": "github:tetherto/wdk-mcp-toolkit",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "^1.0.0-beta.2",
    "@tetherto/wdk-protocol-fiat-moonpay": "^1.0.0-beta.1",
    "@tetherto/wdk-protocol-lending-aave-evm": "^1.0.0-beta.3",
